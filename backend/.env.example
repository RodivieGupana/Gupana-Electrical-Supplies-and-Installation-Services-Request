# PostgreSQL connection
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/gupana_db

# Or individual params (used if DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGDATABASE=gupana_db
PGUSER=postgres
PGPASSWORD=yourpassword

# App
PORT=4000
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS - the origin(s) your frontend is served from
CLIENT_ORIGIN=http://localhost:5500
